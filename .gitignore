class MainActivity : AppCompatActivity() {

    // Data Variables
    private var basePrice: Double = 0.0
    private var shippingCost: Double = 0.0
    private val discountPercent = 0.05

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        // --- STEP 1: Product Selection ---
        // Assuming you have buttons for vehicles
        val carButton = findViewById<Button>(R.id.btn_select_car)
        
        carButton.setOnClickListener {
            basePrice = 30000.0 // Example price
            productNameDisplay.text = "Model S"
            
            // Transition to Calculation Section
            selectionLayout.visibility = View.GONE
            calculationLayout.visibility = View.VISIBLE
            
            updateTotalDisplay()
        }

        // --- STEP 2: Shipping Logic ---
        val radioGroup = findViewById<RadioGroup>(R.id.shipping_group)
        radioGroup.setOnCheckedChangeListener { _, checkedId ->
            shippingCost = if (checkedId == R.id.radio_express) 1700.0 else 0.0
            updateTotalDisplay()
        }

        // --- STEP 3: Payment/Navigation ---
        val payButton = findViewById<Button>(R.id.btn_pay)
        payButton.setOnClickListener {
            calculationLayout.visibility = View.GONE
            successLayout.visibility = View.VISIBLE
        }
    }

    /**
     * Handles the mathematical precision for the final total.
     */
    private fun updateTotalDisplay() {
        // Apply 5% discount: Price * 0.95
        val discountedPrice = basePrice * (1 - discountPercent)
        
        // Add shipping
        val finalTotal = discountedPrice + shippingCost
        
        // Format to display as currency (e.g., $28,500.00)
        totalTextView.text = "Total: $${String.format("%.2f", finalTotal)}"
        
        // Also display breakdown for clarity
        discountDisplay.text = "Discount applied: 5%"
    }
}
